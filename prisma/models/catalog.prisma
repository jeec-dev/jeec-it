// ======================================================
// CATALOG
// Source of truth for JeeC releases and tracks.
// External APIs can enrich/validate these records,
// but should not overwrite canonical editorial fields.
// ======================================================

model Artist {
  id        String   @id @default(uuid())
  slug      String   @unique
  stageName String
  legalName String?

  releases  Release[]
  externalIds ExternalIdentifier[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Release {
  id          String        @id @default(uuid())
  slug        String        @unique
  title       String
  type        ReleaseType
  status      PublishStatus @default(DRAFT)

  year        Int?
  label       String?
  description String?
  lore        String?

  artistId    String
  artist      Artist        @relation(fields: [artistId], references: [id])

  tracks      Track[]
  externalIds   ExternalIdentifier[]
  externalLinks ExternalLink[]

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Track {
  id          String   @id @default(uuid())
  slug        String
  title       String
  position    Int?
  durationMs  Int?
  isrc        String?

  releaseId   String
  release     Release  @relation(fields: [releaseId], references: [id])

  externalIds   ExternalIdentifier[]
  externalLinks ExternalLink[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([releaseId, slug])
}
// ======================================================
// EXTERNAL INTEGRATIONS
// Spotify, Apple Music, YouTube, Deezer, Bandsintown,
// Eventbrite, MusicBrainz, Genius, Amazon Music, SoundCloud.
//
// External integrations enrich, validate and synchronize data.
// They must not overwrite canonical JeeC editorial fields directly.
// ======================================================

model ExternalSource {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  baseUrl   String?
  enabled   Boolean  @default(true)

  identifiers ExternalIdentifier[]
  links       ExternalLink[]
  snapshots  ApiSnapshot[]
  syncRuns   SyncRun[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExternalIdentifier {
  id         String @id @default(uuid())

  sourceId   String
  source     ExternalSource @relation(fields: [sourceId], references: [id])

  entityType ExternalEntityType
  externalId String
  externalUrl String?

  artistId   String?
  artist     Artist?  @relation(fields: [artistId], references: [id])

  releaseId  String?
  release    Release? @relation(fields: [releaseId], references: [id])

  trackId    String?
  track      Track?   @relation(fields: [trackId], references: [id])

  verificationStatus VerificationStatus @default(PENDING)
  lastSyncedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([entityType])
  @@index([artistId])
  @@index([releaseId])
  @@index([trackId])
  @@index([verificationStatus])
  @@index([sourceId, entityType, externalId])

  @@unique([sourceId, entityType, externalId, artistId], name: "external_identifier_artist_unique")
  @@unique([sourceId, entityType, externalId, releaseId], name: "external_identifier_release_unique")
  @@unique([sourceId, entityType, externalId, trackId], name: "external_identifier_track_unique")
  
}

model ExternalLink {
  id        String @id @default(uuid())

  sourceId  String
  source    ExternalSource @relation(fields: [sourceId], references: [id])

  type      ExternalLinkType
  label     String
  url       String
  isPrimary Boolean @default(false)
  isPublic  Boolean @default(true)
  order     Int     @default(0)

  releaseId String?
  release   Release? @relation(fields: [releaseId], references: [id])

  trackId   String?
  track     Track?   @relation(fields: [trackId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sourceId])
  @@index([type])
  @@index([releaseId])
  @@index([trackId])
  @@index([isPublic])
}

model SyncRun {
  id        String @id @default(uuid())

  sourceId  String
  source    ExternalSource @relation(fields: [sourceId], references: [id])

  status    SyncStatus @default(RUNNING)
  startedAt DateTime   @default(now())
  finishedAt DateTime?

  summary   Json?
  error     String?

  snapshots ApiSnapshot[]
  issues    SyncIssue[]

  @@index([sourceId])
  @@index([status])
  @@index([startedAt])
}

model ApiSnapshot {
  id          String @id @default(uuid())

  sourceId    String
  source      ExternalSource @relation(fields: [sourceId], references: [id])

  syncRunId   String?
  syncRun     SyncRun? @relation(fields: [syncRunId], references: [id])

  entityType  ExternalEntityType
  externalId  String?
  payload     Json
  payloadHash String?

  fetchedAt   DateTime @default(now())

  @@index([sourceId])
  @@index([syncRunId])
  @@index([entityType])
  @@index([externalId])
  @@index([fetchedAt])
}

model SyncIssue {
  id          String @id @default(uuid())

  syncRunId   String?
  syncRun     SyncRun? @relation(fields: [syncRunId], references: [id])

  sourceId    String?
  entityType  ExternalEntityType
  entityId    String?

  fieldName   String?
  localValue  String?
  remoteValue String?

  severity    SyncIssueSeverity @default(INFO)
  status      SyncIssueStatus   @default(OPEN)

  createdAt   DateTime @default(now())
  resolvedAt  DateTime?

  @@index([syncRunId])
  @@index([sourceId])
  @@index([entityType])
  @@index([entityId])
  @@index([severity])
  @@index([status])
}